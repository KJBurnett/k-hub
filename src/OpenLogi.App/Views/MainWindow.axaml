<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OpenLogi.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="720" d:DesignHeight="480"
        x:Class="OpenLogi.App.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Width="720" Height="480"
        Title="OpenLogi">

    <Design.DataContext>
        <vm:MainViewModel />
    </Design.DataContext>

    <DockPanel Margin="16">

        <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,12">
            <TextBlock Text="OpenLogi" FontSize="24" FontWeight="Bold" />
            <TextBlock Text="A lightweight, offline-first Logitech mouse manager."
                       Opacity="0.7" />
        </StackPanel>

        <TextBlock DockPanel.Dock="Bottom" Margin="0,12,0,0"
                   Text="{Binding StatusText}" Opacity="0.8" />

        <Border BorderBrush="#33888888" BorderThickness="1" CornerRadius="6" Padding="8">
            <ScrollViewer>
                <ItemsControl ItemsSource="{Binding Devices}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:DeviceListItem">
                            <Border Margin="0,0,0,8" Padding="12"
                                    Background="#22888888" CornerRadius="6">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold" />
                                    <StackPanel Orientation="Horizontal" Spacing="6" Opacity="0.75">
                                        <TextBlock Text="{Binding Tier}" />
                                        <TextBlock Text="·" />
                                        <TextBlock Text="{Binding Connection}" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding Capabilities}" Opacity="0.6"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

    </DockPanel>

</Window>
